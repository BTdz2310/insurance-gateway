generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id                String    @id @default(uuid())
  maGiaodich        String    @unique
  productKind       String
  status            TxStatus
  inboundPayload    Json
  pviRequest        Json?
  pviResponse       Json?
  pviPrKey          String?
  paymentUrl        String?
  policyNumber      String?
  serialNumber      String?
  pdfUrl            String?
  callbackPayload   Json?
  callbackAt        DateTime?
  callbackCardId    String?
  callbackCpId      String?
  reconcileAttempts Int       @default(0)
  lastError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  partnerId         String?
  partner           Partner?  @relation(fields: [partnerId], references: [id])

  @@index([status, createdAt])
  @@index([policyNumber])
  @@index([partnerId])
}

enum TxStatus {
  SUBMITTING
  SUBMITTED_OK
  SUBMITTED_FAIL
  ISSUED
  CALLBACK_TIMEOUT
}

model ApiCallLog {
  id         String   @id @default(uuid())
  direction  String
  endpoint   String
  maGiaodich String?
  request    Json?
  response   Json?
  statusCode Int?
  durationMs Int?
  errorMsg   String?
  createdAt  DateTime @default(now())

  @@index([maGiaodich])
  @@index([createdAt])
}

model Partner {
  id           String          @id @default(uuid())
  name         String
  clientId     String          @unique
  status       PartnerStatus
  rateLimit    Int             @default(0)
  allowedIps   String[]        @default([])
  secrets      PartnerSecret[]
  transactions Transaction[]
  createdAt    DateTime        @default(now())
}

model PartnerSecret {
  id        String       @id @default(uuid())
  partnerId String
  keyId     String
  secretEnc String
  status    SecretStatus
  createdAt DateTime     @default(now())

  partner Partner @relation(fields: [partnerId], references: [id])

  @@unique([partnerId, keyId])
  @@index([partnerId])
  @@index([keyId])
}

enum PartnerStatus {
  ACTIVE
  DISABLED
}

enum SecretStatus {
  ACTIVE
  REVOKED
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
