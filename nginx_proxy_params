# /etc/nginx/proxy_params — copy file này lên server tại đúng path
# Dùng chung cho tất cả location block proxy_pass sang Node.js

proxy_http_version   1.1;
proxy_set_header     Upgrade            $http_upgrade;
proxy_set_header     Connection         "upgrade";
proxy_set_header     Host               $host;
proxy_set_header     X-Real-IP          $remote_addr;
proxy_set_header     X-Forwarded-For    $proxy_add_x_forwarded_for;
proxy_set_header     X-Forwarded-Proto  $scheme;

# Timeout — phù hợp với HTTP_TIMEOUT_MS=15000 trong .env
proxy_connect_timeout   10s;
proxy_send_timeout      30s;
proxy_read_timeout      30s;

# Buffer — tránh disk-buffering cho response JSON nhỏ
proxy_buffering          on;
proxy_buffer_size        4k;
proxy_buffers            8 4k;
proxy_busy_buffers_size  8k;
